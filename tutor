<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>老王“坠楼”边缘的12小时｜互动大屏版</title>
  <style>
    :root{
      --bg:#090b10;
      --panel:#121722;
      --panel-2:#181f2d;
      --line:#2b3448;
      --text:#f3f6fb;
      --muted:#aab4c8;
      --danger:#ff5c6c;
      --warn:#ffb547;
      --ok:#42d392;
      --blue:#5aa9ff;
      --purple:#a78bfa;
      --shadow:0 18px 50px rgba(0,0,0,.35);
      --radius:22px;
    }

    *{box-sizing:border-box}
    html,body{
      margin:0;
      min-height:100%;
      background:
        radial-gradient(circle at top right, rgba(167,139,250,.14), transparent 28%),
        radial-gradient(circle at top left, rgba(90,169,255,.12), transparent 24%),
        linear-gradient(180deg, #090b10 0%, #0d1118 100%);
      color:var(--text);
      font-family:"Microsoft YaHei","PingFang SC","Helvetica Neue",Arial,sans-serif;
    }

    .wrap{
      max-width:1400px;
      margin:0 auto;
      padding:22px;
    }

    .hero{
      display:grid;
      grid-template-columns: 1.4fr .9fr;
      gap:18px;
      margin-bottom:18px;
    }

    .hero-main,.hero-side,.panel,.card,.modal-box{
      background:linear-gradient(180deg, rgba(24,31,45,.95), rgba(18,23,34,.95));
      border:1px solid var(--line);
      border-radius:var(--radius);
      box-shadow:var(--shadow);
    }

    .hero-main{
      padding:22px 24px;
      position:relative;
      overflow:hidden;
      min-height:180px;
    }

    .hero-main::after{
      content:"";
      position:absolute;
      inset:auto -60px -60px auto;
      width:220px;height:220px;
      background:radial-gradient(circle, rgba(255,92,108,.18), transparent 70%);
      pointer-events:none;
    }

    .eyebrow{
      display:inline-flex;
      align-items:center;
      gap:10px;
      color:#ffd6dc;
      font-size:14px;
      letter-spacing:.08em;
      text-transform:uppercase;
      margin-bottom:10px;
    }
    .dot{
      width:10px;height:10px;border-radius:50%;
      background:var(--danger);
      box-shadow:0 0 18px rgba(255,92,108,.85);
      animation:pulse 1.2s infinite;
    }
    @keyframes pulse{
      0%{transform:scale(.9);opacity:.6}
      50%{transform:scale(1.15);opacity:1}
      100%{transform:scale(.9);opacity:.6}
    }

    h1{
      margin:0 0 8px 0;
      font-size:34px;
      line-height:1.2;
      letter-spacing:.01em;
    }

    .subtitle{
      color:var(--muted);
      line-height:1.8;
      font-size:15px;
      max-width:90%;
    }

    .hero-side{
      padding:18px 20px;
      display:flex;
      flex-direction:column;
      justify-content:space-between;
      gap:10px;
    }

    .time{
      font-size:14px;color:var(--muted);
    }

    .big-time{
      font-size:34px;
      font-weight:800;
      color:#fff0f2;
      letter-spacing:.03em;
    }

    .phase-pill{
      display:inline-flex;
      align-items:center;
      padding:10px 14px;
      border-radius:999px;
      background:rgba(255,255,255,.05);
      color:#dbe7ff;
      font-size:14px;
      border:1px solid rgba(255,255,255,.08);
      width:fit-content;
    }

    .layout{
      display:grid;
      grid-template-columns: 1.1fr 1fr;
      gap:18px;
    }

    .left-col,.right-col{
      display:flex;
      flex-direction:column;
      gap:18px;
    }

    .panel{
      padding:18px;
    }

    .panel h2{
      margin:0 0 14px 0;
      font-size:20px;
    }

    .muted{
      color:var(--muted);
      line-height:1.7;
      font-size:14px;
    }

    .score-grid{
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:14px;
    }

    .card{
      padding:18px;
      position:relative;
      overflow:hidden;
    }

    .card small{
      color:var(--muted);
      font-size:13px;
    }

    .score-label{
      display:flex;align-items:center;gap:8px;
      font-size:18px;
      margin-bottom:12px;
    }

    .score-value{
      font-size:58px;
      font-weight:800;
      line-height:1;
      margin-bottom:8px;
    }

    .bar{
      width:100%;
      height:10px;
      background:rgba(255,255,255,.08);
      border-radius:999px;
      overflow:hidden;
      border:1px solid rgba(255,255,255,.06);
    }

    .bar > span{
      display:block;height:100%;
      width:50%;
      border-radius:999px;
      transition:width .35s ease;
    }

    .task span{background:linear-gradient(90deg,#5aa9ff,#83c1ff)}
    .human span{background:linear-gradient(90deg,#ff6b7a,#ff96a1)}
    .org span{background:linear-gradient(90deg,#42d392,#87f0bf)}

    .choice-grid{
      display:grid;
      grid-template-columns:1fr;
      gap:12px;
    }

    .choice{
      display:block;
      width:100%;
      text-align:left;
      border:none;
      border-radius:18px;
      background:linear-gradient(180deg, rgba(255,255,255,.06), rgba(255,255,255,.03));
      color:var(--text);
      padding:16px 16px 14px;
      cursor:pointer;
      border:1px solid rgba(255,255,255,.08);
      transition:transform .16s ease, border-color .16s ease, background .16s ease;
    }

    .choice:hover{
      transform:translateY(-2px);
      border-color:rgba(255,255,255,.18);
      background:linear-gradient(180deg, rgba(255,255,255,.09), rgba(255,255,255,.04));
    }

    .choice-title{
      font-size:18px;
      font-weight:700;
      margin-bottom:6px;
    }

    .choice-desc{
      color:var(--muted);
      line-height:1.7;
      font-size:14px;
    }

    .delta{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
      margin-top:10px;
      font-size:13px;
    }

    .tag{
      padding:6px 10px;
      border-radius:999px;
      background:rgba(255,255,255,.06);
      border:1px solid rgba(255,255,255,.08);
    }

    .ops{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
      margin-top:14px;
    }

    .btn{
      border:none;
      border-radius:14px;
      padding:12px 16px;
      font-size:14px;
      cursor:pointer;
      color:white;
      transition:transform .16s ease, opacity .16s ease;
    }
    .btn:hover{transform:translateY(-1px)}
    .btn-primary{background:linear-gradient(135deg,#4f8cff,#2a67f9)}
    .btn-danger{background:linear-gradient(135deg,#ff6676,#e83c58)}
    .btn-gray{background:linear-gradient(135deg,#4b5568,#354055)}
    .btn-ok{background:linear-gradient(135deg,#2dcf88,#13a865)}

    .log{
      min-height:280px;
      max-height:360px;
      overflow:auto;
      background:#0d121c;
      border:1px solid rgba(255,255,255,.07);
      border-radius:16px;
      padding:14px;
      line-height:1.75;
      white-space:pre-line;
      font-size:14px;
    }

    .ending{
      padding:16px;
      border-radius:18px;
      background:linear-gradient(180deg, rgba(255,255,255,.05), rgba(255,255,255,.02));
      border:1px solid rgba(255,255,255,.08);
    }

    .ending-title{
      font-size:22px;
      font-weight:800;
      margin-bottom:8px;
    }

    .ending-copy{
      line-height:1.9;
      color:#e6ebf6;
      white-space:pre-line;
    }

    .legend{
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:10px;
      margin-top:12px;
    }

    .legend .item{
      border-radius:14px;
      padding:12px;
      background:rgba(255,255,255,.04);
      border:1px solid rgba(255,255,255,.06);
      font-size:13px;
      line-height:1.6;
      color:var(--muted);
    }

    .foot{
      margin-top:16px;
      color:var(--muted);
      font-size:13px;
      text-align:center;
    }

    .modal{
      position:fixed;
      inset:0;
      background:rgba(4,6,10,.62);
      display:none;
      align-items:center;
      justify-content:center;
      padding:24px;
      z-index:100;
    }

    .modal.show{display:flex}

    .modal-box{
      width:min(760px, 100%);
      padding:24px;
    }

    .modal-box h3{
      margin:0 0 10px 0;
      font-size:28px;
    }
    .modal-box p{
      color:#e9edf7;
      line-height:1.95;
      font-size:17px;
      white-space:pre-line;
    }

    .modal-meta{
      color:var(--muted);
      margin-bottom:10px;
      font-size:14px;
    }

    
    .role-grid{
      display:grid;
      grid-template-columns:repeat(4,1fr);
      gap:12px;
      align-items:start;
    }

    .role-card{
      border-radius:20px;
      overflow:hidden;
      background:
        linear-gradient(180deg, rgba(255,255,255,.06), rgba(255,255,255,.02)),
        linear-gradient(180deg, #141a27, #101521);
      border:1px solid rgba(255,255,255,.08);
      min-height: 0;
      box-shadow: 0 10px 30px rgba(0,0,0,.22);
    }

    .role-head{
      padding:10px 12px 2px;
      font-size:16px;
      font-weight:800;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:8px;
      line-height:1.2;
    }

    .role-sub{
      padding:0 12px 8px;
      color:var(--muted);
      font-size:12px;
      line-height:1.5;
    }

    .role-card img{
      width:100%;
      height:260px;
      object-fit:contain;
      object-position:center top;
      display:block;
      background:transparent;
      padding:2px 6px 0;
    }

    .role-copy{
      padding:8px 12px 12px;
      font-size:12px;
      line-height:1.65;
      color:#e7edf9;
      border-top:1px solid rgba(255,255,255,.06);
      background:linear-gradient(180deg, rgba(255,255,255,.02), rgba(255,255,255,.00));
    }

    .role-copy b{
      color:#fff;
    }

    .role-doctor .role-head{color:#7cc0ff}
    .role-psych .role-head{color:#8be18f}
    .role-social .role-head{color:#d29cff}
    .role-super .role-head{color:#ffbf6b}

    .role-social-fix img{
      transform:none;
    }


    .role-card{
      cursor:pointer;
      transition:transform .22s ease, box-shadow .22s ease, border-color .22s ease, background .22s ease, opacity .22s ease;
      position:relative;
    }

    .role-card:hover{
      transform:translateY(-2px);
      border-color:rgba(255,255,255,.16);
    }

    .role-card.is-active{
      transform:scale(1.06);
      border-color:rgba(255,255,255,.22);
      box-shadow:0 22px 50px rgba(0,0,0,.35);
      z-index:3;
      background:
        linear-gradient(180deg, rgba(255,255,255,.08), rgba(255,255,255,.03)),
        linear-gradient(180deg, #171f2f, #101521);
    }

    .role-stance{
      max-height:0;
      overflow:hidden;
      opacity:0;
      padding:0 12px;
      border-top:1px solid rgba(255,255,255,0);
      background:linear-gradient(180deg, rgba(255,255,255,.03), rgba(255,255,255,.01));
      transition:max-height .26s ease, opacity .2s ease, padding .2s ease, border-color .2s ease;
    }

    .role-card.is-active .role-stance{
      max-height:120px;
      opacity:1;
      padding:10px 12px 12px;
      border-top:1px solid rgba(255,255,255,.08);
    }

    .role-stance-title{
      font-size:12px;
      letter-spacing:.08em;
      text-transform:uppercase;
      color:var(--muted);
      margin-bottom:6px;
    }

    .role-stance-copy{
      font-size:13px;
      line-height:1.75;
      color:#ffffff;
    }

    .role-grid.role-focus-mode .role-card:not(.is-active){
      opacity:.62;
      transform:scale(.97);
    }


@media (max-width:1100px){
      .hero,.layout{grid-template-columns:1fr}
      .score-grid{grid-template-columns:1fr}
      .role-grid{grid-template-columns:1fr}
      .legend{grid-template-columns:1fr}
      h1{font-size:28px}
      .big-time{font-size:28px}
    }
  </style>
</head>
<body>
  <div class="wrap">
    <section class="hero">
      <div class="hero-main">
        <div class="eyebrow"><span class="dot"></span> INTERACTIVE SUPERVISION SIMULATION</div>
        <h1>老王“坠楼”边缘的 12 小时</h1>
        <div class="subtitle">
          你们不是来听课的，你们是这支跨学科团队的督导。<br>
          今天没有“标准答案”，只有取舍、代价和后果。
        </div>
      </div>
      <div class="hero-side">
        <div>
          <div class="time">倒计时情境</div>
          <div class="big-time" id="clockLabel">12 小时前</div>
        </div>
        <div class="phase-pill" id="phaseText">第一轮：选择主导策略</div>
        <div class="muted">建议操作：第一轮选一次 → 第二轮选一次 → 点击“结算结局” → 课堂复盘</div>
      </div>
    </section>

    
    <section class="panel" style="margin-bottom:18px;">
      <h2 style="margin-bottom:10px;">角色卡</h2>
      
      <div class="role-grid">
        <div class="role-card role-doctor" onclick="toggleRoleCard(this)">
          <div class="role-head">医疗组 <span>🩺</span></div>
          <div class="role-sub">安全 / 效率 / 风险控制</div>
          <img src="data:image/png;base64," alt="医疗组形象">
          <div class="role-copy"><b>关键词：</b>先保命、先控风险、快速处置。</div>
        <div class="role-stance">
          <div class="role-stance-title">stance</div>
          <div class="role-stance-copy">医疗组的立场是：<b>安全优先</b>。只要老王还处在高风险状态，任何搬离、沟通、协调都必须为“先保命”让路。</div>
        </div>
        </div>
        <div class="role-card role-psych" onclick="toggleRoleCard(this)">
          <div class="role-head">心理组 <span>🧠</span></div>
          <div class="role-sub">情绪 / 权利 / 心理稳定</div>
          <img src="data:image/png;base64," alt="心理组形象">
          <div class="role-copy"><b>关键词：</b>先稳情绪、尊重选择、避免刺激升级。</div>
        <div class="role-stance">
          <div class="role-stance-title">stance</div>
          <div class="role-stance-copy">心理组的立场是：<b>情绪优先</b>。如果继续施压，只会让老王更绝望；先稳定情绪，后面的方案才有可能被接受。</div>
        </div>
        </div>
        <div class="role-card role-social role-social-fix" onclick="toggleRoleCard(this)">
          <div class="role-head">社工组 <span>📋</span></div>
          <div class="role-sub">资源 / 系统 / 社会网络</div>
          <img src="data:image/png;base64," alt="社工组形象">
          <div class="role-copy"><b>关键词：</b>协调资源、连接系统、解决现实落点。</div>
        <div class="role-stance">
          <div class="role-stance-title">stance</div>
          <div class="role-stance-copy">社工组的立场是：<b>现实落地优先</b>。房子、安置、资源、系统支持不解决，老王的危机就会反复出现，情绪稳定也很难持续。</div>
        </div>
        </div>
        
<div class="role-card role-super" onclick="toggleRoleCard(this)">
  <div class="role-head">督导组 <span>⚖️</span></div>
  <div class="role-sub">整合 / 决策 / 取舍</div>
  <img src="data:image/png;base64," alt="督导组形象">
  <div class="role-copy"><b>关键词：</b>整合意见、做出取舍、对结局负责。</div>
        <div class="role-stance">
          <div class="role-stance-title">stance</div>
          <div class="role-stance-copy">督导组的立场是：<b>取舍优先</b>。督导不是折中所有意见，而是在冲突中决定先保什么、愿意牺牲什么，并对结局负责。</div>
        </div>
</div>

      </div>
    </section>


    <section class="layout">
      <div class="left-col">
        <div class="panel">
          <h2>团队状态面板</h2>
          <div class="muted" style="margin-bottom:12px;">我们用三个维度观察团队：执行、关系、系统。</div>
          <div class="score-grid">
            <div class="card task">
              <div class="score-label">🧭 执行值</div>
              <div class="score-value" id="taskScore">5</div>
              <div class="bar"><span id="taskBar"></span></div>
              <div class="muted" style="margin-top:10px;">目标清晰、行动推进、执行效率</div>
            </div>
            <div class="card human">
              <div class="score-label">❤️ 关系值</div>
              <div class="score-value" id="humanScore">5</div>
              <div class="bar"><span id="humanBar"></span></div>
              <div class="muted" style="margin-top:10px;">情绪稳定、信任关系、心理安全</div>
            </div>
            <div class="card org">
              <div class="score-label">🏢 系统值</div>
              <div class="score-value" id="orgScore">5</div>
              <div class="bar"><span id="orgBar"></span></div>
              <div class="muted" style="margin-top:10px;">资源支持、制度空间、协作条件</div>
            </div>
          </div>
        </div>

        <div class="panel">
          <h2 id="choiceHeading">第一轮：督导必须选择一种主导策略</h2>
          <div class="muted" id="choiceSub">
            不提供“综合方案”。真实督导情境中，你必须决定优先保什么，又愿意牺牲什么。
          </div>
          <div class="choice-grid" id="choicesBox"></div>
          <div class="ops">
            <button class="btn btn-primary" onclick="nextPhase()">进入下一阶段</button>
            <button class="btn btn-ok" onclick="judgeEnding()">结算结局</button>
            <button class="btn btn-gray" onclick="showPrompt()">显示主持人提示词</button>
            <button class="btn btn-danger" onclick="resetAll()">重置全局</button>
          </div>
        </div>
      </div>

      <div class="right-col">
        <div class="panel">
          <h2>事件记录</h2>
          <div class="log" id="logBox">系统已启动。
初始数值：任务5 / 关系5 / 系统5
主持人提示：先让各组陈述理由，再由督导组表态。</div>
        </div>

        <div class="panel">
          <h2>当前结局判断</h2>
          <div class="ending">
            <div class="ending-title" id="endingTitle">尚未结算</div>
            <div class="ending-copy" id="endingCopy">当三条数值发生明显失衡时，结局会自动偏向不同方向。你们的选择，会决定老王、团队和项目的命运。</div>
          </div>

          <div class="legend">
            <div class="item">🟥 关系值过低：关系断裂、情绪失控，可能出现极端风险。</div>
            <div class="item">🟨 系统值过低：资源与制度空间耗尽，项目系统性崩盘。</div>
            <div class="item">🟩 三项相对平衡：不代表完美，只代表督导完成了有限条件下的取舍。</div>
          </div>
        </div>
      </div>
    </section>

    <div class="foot">适用于课堂互动展示｜本地打开即可运行｜无需联网</div>
  </div>

  <div class="modal" id="modal">
    <div class="modal-box">
      <div class="modal-meta" id="modalMeta">主持人提示</div>
      <h3 id="modalTitle">标题</h3>
      <p id="modalBody">内容</p>
      <div class="ops">
        <button class="btn btn-primary" onclick="closeModal()">关闭</button>
      </div>
    </div>
  </div>

  <script>
    const state = {
      phase: 1,
      firstDone: false,
      secondDone: false,
      scores: { task: 5, human: 5, org: 5 },
      round1Choice: null
    };

    const phaseConfig = {
      1: {
        clock: "12 小时前",
        phaseText: "第一轮：选择主导策略",
        heading: "第一轮：督导必须选择一种主导策略",
        sub: "不提供“综合方案”。真实督导情境中，你必须决定优先保什么，又愿意牺牲什么。",
        choices: [
          {
            key: "efficiency",
            title: "A. 优先效率",
            desc: "由医疗逻辑主导，立刻压缩讨论，快速推进处置。优点是行动果断；代价是可能激化情绪，损害信任。",
            delta: {task: +2, human: -2, org: +1},
            tags: ["执行 +2", "关系 -2", "系统 +1"],
            log: "第一轮选择：优先效率。团队执行力上升，但老王与成员的情绪承载开始恶化。"
          },
          {
            key: "emotion",
            title: "B. 优先情绪",
            desc: "由心理逻辑主导，先稳定老王和团队的情绪，暂缓刚性推进。优点是关系缓和；代价是决策拖慢，行政压力上升。",
            delta: {task: -1, human: +2, org: -1},
            tags: ["执行 -1", "关系 +2", "系统 -1"],
            log: "第一轮选择：优先情绪。关系暂时稳住，但组织对延迟开始不满。"
          },
          {
            key: "resource",
            title: "C. 优先资源",
            desc: "由社工逻辑主导，先协调居住、转介、外部支持等资源，力图为执行创造空间。优点是争取缓冲；代价是制度成本迅速上升。",
            delta: {task: +1, human: +1, org: -2},
            tags: ["执行 +1", "关系 +1", "系统 -2"],
            log: "第一轮选择：优先资源。表面形成缓冲，但组织资源被快速消耗。"
          }
        ]
      },
      2: {
        clock: "2 小时后",
        phaseText: "第二轮：危机应对",
        heading: "第二轮：系统开始失衡，你要怎么救场？",
        sub: "这一轮不再是“你想怎么做”，而是“前面那次选择，把你逼到哪一步了”。",
        choices: [
          {
            key: "push",
            title: "A. 强推任务",
            desc: "压制争论，优先完成处置。短期可能推进，但团队中的人际裂缝会进一步扩大。",
            delta: {task: +1, human: -2, org: 0},
            tags: ["执行 +1", "关系 -2", "组织 0"],
            log: "第二轮选择：强推任务。你保住了行动，但进一步透支了关系。"
          },
          {
            key: "soothe",
            title: "B. 先处理情绪",
            desc: "暂停推进，先处理老王与团队成员的情绪与冲突。短期降速，但可避免失控。",
            delta: {task: -1, human: +2, org: -1},
            tags: ["执行 -1", "关系 +2", "系统 -1"],
            log: "第二轮选择：先处理情绪。你为团队争取了呼吸，但组织容忍度下降。"
          },
          {
            key: "blame",
            title: "C. 甩锅他人",
            desc: "把责任外推给其他学科、街道或案家。表面减压，但跨学科信任会被迅速摧毁。",
            delta: {task: 0, human: -2, org: +1},
            tags: ["执行 0", "关系 -2", "系统 +1"],
            log: "第二轮选择：甩锅他人。你暂时稳住表面秩序，但团队信任明显崩坏。"
          }
        ]
      },
      3: {
        clock: "12 小时后",
        phaseText: "第三轮：结局与复盘",
        heading: "第三轮：请结算结局，并引导全班复盘",
        sub: "此时不再做操作，重点是追问：为什么会走到这一步？",
        choices: []
      }
    };

    function $(id){ return document.getElementById(id); }

    function clamp(n){
      return Math.max(0, Math.min(10, n));
    }

    function updateBars(){
      $("taskBar").style.width = (state.scores.task * 10) + "%";
      $("humanBar").style.width = (state.scores.human * 10) + "%";
      $("orgBar").style.width = (state.scores.org * 10) + "%";
    }

    function updateScores(){
      $("taskScore").textContent = state.scores.task;
      $("humanScore").textContent = state.scores.human;
      $("orgScore").textContent = state.scores.org;
      updateBars();
    }

    function log(msg){
      const box = $("logBox");
      box.textContent += "\n" + msg + ` 当前数值：执行${state.scores.task} / 关系${state.scores.human} / 系统${state.scores.org}`;
      box.scrollTop = box.scrollHeight;
    }

    function openModal(title, body, meta="主持人提示"){
      $("modalTitle").textContent = title;
      $("modalBody").textContent = body;
      $("modalMeta").textContent = meta;
      $("modal").classList.add("show");
    }

    function closeModal(){
      $("modal").classList.remove("show");
    }

    function changeScore(delta, msg){
      state.scores.task = clamp(state.scores.task + delta.task);
      state.scores.human = clamp(state.scores.human + delta.human);
      state.scores.org = clamp(state.scores.org + delta.org);
      updateScores();
      log(msg);
    }

    function renderPhase(){
      const cfg = phaseConfig[state.phase];
      $("clockLabel").textContent = cfg.clock;
      $("phaseText").textContent = cfg.phaseText;
      $("choiceHeading").textContent = cfg.heading;
      $("choiceSub").textContent = cfg.sub;

      const box = $("choicesBox");
      box.innerHTML = "";

      if (!cfg.choices.length){
        const div = document.createElement("div");
        div.className = "muted";
        div.style.marginTop = "8px";
        div.textContent = "现在请点击“结算结局”，然后带领同学依据结果进行过程评估与理论复盘。";
        box.appendChild(div);
        return;
      }

      cfg.choices.forEach(choice=>{
        const btn = document.createElement("button");
        btn.className = "choice";
        btn.onclick = ()=> applyChoice(choice);

        btn.innerHTML = `
          <div class="choice-title">${choice.title}</div>
          <div class="choice-desc">${choice.desc}</div>
          <div class="delta">
            ${choice.tags.map(t=>`<span class="tag">${t}</span>`).join("")}
          </div>
        `;
        box.appendChild(btn);
      });
    }

    function applyChoice(choice){
      if (state.phase === 1 && state.firstDone){
        openModal("第一轮已完成", "为了保持课堂张力，第一轮只允许做一次选择。请进入第二轮。");
        return;
      }
      if (state.phase === 2 && state.secondDone){
        openModal("第二轮已完成", "第二轮危机应对已经记录。现在可以直接结算结局。");
        return;
      }
      if (state.phase === 3){
        openModal("现在进入复盘阶段", "第三轮不再做策略选择。请直接点击“结算结局”，并带领同学复盘团队为什么会走向这个结果。");
        return;
      }

      changeScore(choice.delta, choice.log);

      if (state.phase === 1){
        state.firstDone = true;
        state.round1Choice = choice.key;
        triggerRound1Consequence(choice.key);
      } else if (state.phase === 2){
        state.secondDone = true;
      }
    }

    function triggerRound1Consequence(key){
      let title = "系统反馈";
      let body = "";

      if (key === "efficiency"){
        state.scores.human = clamp(state.scores.human - 1);
        updateScores();
        log("系统反馈：由于前期过度强调效率，老王情绪波动加剧，成员间开始互相指责。");
        body = "由于你们优先保效率，团队很快推进了流程。\n\n但副作用也立刻出现：\n- 老王的情绪明显恶化\n- 团队成员开始互相埋怨\n- 你们保住了行动，却开始失去人\n\n主持人追问：\n“如果一个方案是有效的，但会把人推向边缘，它还算成功吗？”";
      } else if (key === "emotion"){
        state.scores.org = clamp(state.scores.org - 1);
        updateScores();
        log("系统反馈：由于前期过度强调情绪稳定，街道与组织方对延误表示强烈不满。");
        body = "由于你们优先保情绪，团队关系暂时缓和。\n\n但行政系统开始施压：\n- 街道办催促加码\n- 资源容忍度下降\n- 组织方开始怀疑团队执行力\n\n主持人追问：\n“如果一个方案很尊重人，但最后连基本任务都完不成，谁来承担后果？”";
      } else if (key === "resource"){
        state.scores.org = clamp(state.scores.org - 1);
        updateScores();
        log("系统反馈：由于前期大量调用外部资源，组织空间进一步收缩，协调成本暴涨。");
        body = "由于你们优先保资源，团队争取到了一定缓冲。\n\n但代价是：\n- 外部协调成本迅速升高\n- 行政系统开始怀疑这件事是否值得继续投入\n- 看似稳住局面，其实组织空间更紧了\n\n主持人追问：\n“如果资源越调越乱，督导到底是在解决问题，还是在拖延问题？”";
      }

      openModal(title, body, "第一轮后果");
    }

    function nextPhase(){
      if (state.phase === 1 && !state.firstDone){
        openModal("还不能进入下一阶段", "第一轮还没有做出主导策略选择。请先让督导组完成表态。");
        return;
      }
      if (state.phase === 2 && !state.secondDone){
        openModal("还不能进入复盘", "第二轮危机应对还没有完成。请先做出一次危机处理选择。");
        return;
      }
      state.phase = Math.min(3, state.phase + 1);
      renderPhase();

      if (state.phase === 2){
        openModal(
          "进入第二轮：系统开始崩溃",
          "现在你们不再拥有“理想选择”。\n\n你们要处理的，不是一个抽象案例，\n而是上一轮选择留下来的后果。\n\n请让督导组再次决定：\n这一次，优先保任务，还是优先保人，还是优先保住自己？",
          "阶段切换"
        );
      } else if (state.phase === 3){
        openModal(
          "进入第三轮：结局与复盘",
          "现在请点击“结算结局”。\n\n结算之后，不要急着讲理论。\n先问全班：\n- 你们刚才真的在合作吗？\n- 你们的冲突被处理了吗？\n- 你们还是一个团队吗？",
          "阶段切换"
        );
      }
    }

    function judgeEnding(){
      let title = "";
      let copy = "";

      const {task, human, org} = state.scores;

      if (human <= 2){
        title = "🟥 结局：人先垮了";
        copy = "老王进入极高危状态，团队成员之间也已经失去基本信任。\n\n你们也许保住了某些流程，但没有保住人。\n这不是跨学科协作，这是多方同时崩盘。";
      } else if (org <= 2){
        title = "🟨 结局：系统先垮了";
        copy = "组织耐受度耗尽，资源撤离，项目被迫中断。\n\n你们努力过，但没有守住制度空间。\n没有组织支持，任何专业判断都难以落地。";
      } else if (task <= 2){
        title = "🟧 结局：关系还在，行动失败";
        copy = "团队关系勉强维持，老王也暂时没有进一步失控。\n\n但任务没有真正推进，问题只是被推迟，而不是被解决。";
      } else {
        title = "🟩 结局：勉强稳住";
        copy = "老王暂时脱离极端危险，团队和系统也没有完全崩塌。\n\n这不意味着你们做得完美，\n只意味着在有限条件下，你们完成了一次艰难但有效的取舍。";
      }

      $("endingTitle").textContent = title;
      $("endingCopy").textContent = copy;

      openModal(
        title,
        copy + "\n\n主持人收束句：\n“真正决定结局的，不是某个学科说得更有道理，而是督导如何在冲突中做出取舍，并承担后果。”",
        "结局判定"
      );
    }

    function showPrompt(){
      const prompts = {
        1: "第一轮主持人提问：\n\n“现在你们只能保一样：效率、情绪，还是资源空间？”\n“不要告诉我理想答案，告诉我你愿意牺牲什么。”\n“督导组注意：你们不是来折中的，你们是来承担后果的。”",
        2: "第二轮主持人提问：\n\n“前一轮的选择已经造成后果，现在你们怎么救场？”\n“这一次你们还想保所有人吗？”\n“如果继续推进，谁会先垮？如果暂停推进，谁来承担制度代价？”",
        3: "第三轮主持人提问：\n\n“你们刚才真的形成团队了吗？”\n“你们处理的是问题，还是只是在处理彼此的不满？”\n“如果结果完成了，但团队死了，这算成功吗？”"
      };
      openModal("主持人提示词", prompts[state.phase], "课堂控场台词");
    }

    function resetAll(){
      state.phase = 1;
      state.firstDone = false;
      state.secondDone = false;
      state.round1Choice = null;
      state.scores = {task: 5, human: 5, org: 5};
      $("logBox").textContent = "系统已重置。\n初始数值：任务5 / 关系5 / 系统5\n主持人提示：先让各组陈述理由，再由督导组表态。";
      $("endingTitle").textContent = "尚未结算";
      $("endingCopy").textContent = "当三条数值发生明显失衡时，结局会自动偏向不同方向。你们的选择，会决定老王、团队和项目的命运。";
      updateScores();
      renderPhase();
    }


    function toggleRoleCard(card){
      const grid = document.querySelector('.role-grid');
      const isActive = card.classList.contains('is-active');
      document.querySelectorAll('.role-card').forEach(el => el.classList.remove('is-active'));
      if(grid){ grid.classList.remove('role-focus-mode'); }
      if(!isActive){
        card.classList.add('is-active');
        if(grid){ grid.classList.add('role-focus-mode'); }
      }
    }

    updateScores();
    renderPhase();
  </script>
</body>
</html>
