<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <title>残疾人就业政策博弈模拟器 V3.0 (多维因素版)</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body { font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif; background-color: #f4f7f9; padding: 20px; color: #333; }
        .container { max-width: 1100px; margin: 0 auto; background: white; padding: 30px; border-radius: 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); }
        h2 { text-align: center; color: #2c3e50; border-bottom: 3px solid #3498db; padding-bottom: 15px; }
        .main-layout { display: grid; grid-template-columns: 400px 1fr; gap: 30px; margin-top: 25px; }
        .control-panel { background: #f8fafc; padding: 20px; border-radius: 10px; border: 1px solid #e2e8f0; }
        .section-title { font-size: 14px; font-weight: bold; color: #1a3a5a; margin-bottom: 15px; background: #e0e7ff; padding: 5px 10px; border-radius: 4px; }
        .control-group { margin-bottom: 18px; }
        label { display: block; font-size: 12px; font-weight: 600; color: #475569; margin-bottom: 6px; }
        input[type="range"] { width: 100%; height: 5px; border-radius: 5px; background: #cbd5e1; outline: none; transition: 0.3s; }
        .val-tag { float: right; color: #3498db; font-family: 'Courier New', monospace; font-size: 14px; }
        .analysis-card { background: #fff; border: 1px solid #e2e8f0; border-radius: 10px; padding: 20px; display: flex; flex-direction: column; }
        .chart-box { flex-grow: 1; min-height: 350px; }
        .status-bar { padding: 15px; border-radius: 6px; text-align: center; font-weight: bold; font-size: 16px; margin-bottom: 20px; }
        .safe { background: #dcfce7; color: #166534; border: 1px solid #bbf7d0; }
        .danger { background: #fee2e2; color: #991b1b; border: 1px solid #fecaca; }
        .insight-box { margin-top: 15px; background: #f1f5f9; padding: 15px; border-radius: 6px; font-size: 13px; line-height: 1.6; }
    </style>
</head>
<body>

<div class="container">
    <h2>残疾人就业政策博弈模拟器 V3.0 <small style="font-size: 14px; color: #64748b;">(整合多维障碍因素)</small></h2>
    
    <div class="main-layout">
        <div class="control-panel">
            <div class="section-title">制度参数 (外部驱动)</div>
            <div class="control-group">
                <label>政策强度 (每人年缴纳额) <span class="val-tag" id="levy-val">50,000</span></label>
                <input type="range" id="levy" min="0" max="100000" step="1000" value="50000">
            </div>
            <div class="control-group">
                <label>监管刚性 (被查处概率) <span class="val-tag" id="audit-val">10%</span></label>
                <input type="range" id="audit" min="0" max="100" step="1" value="10">
            </div>

            <div class="section-title">雇佣障碍 (参考你提供的多维因素图)</div>
            <div class="control-group">
                <label>物理环境/改造难度 <span class="val-tag" id="env-val">10,000</span></label>
                <input type="range" id="env" min="0" max="30000" step="500" value="10000">
            </div>
            <div class="control-group">
                <label>沟通成本/偏见预期 <span class="val-tag" id="psych-val">15,000</span></label>
                <input type="range" id="psych" min="0" max="40000" step="500" value="15000">
            </div>
            <div class="control-group">
                <label>匹配/招聘信息成本 <span class="val-tag" id="match-val">5,000</span></label>
                <input type="range" id="match" min="0" max="20000" step="500" value="5000">
            </div>
            
            <div style="font-size: 11px; color: #64748b; font-style: italic;">
                * 核心算法：管理总成本 = 环境改造 + 心理偏见 + 匹配成本
            </div>
        </div>

        <div class="analysis-card">
            <div id="status-tag" class="status-bar">计算中...</div>
            <div class="chart-box">
                <canvas id="costChart"></canvas>
            </div>
            <div class="insight-box">
                <strong>💡 深度诊断：</strong>
                <p id="insight-text"></p>
            </div>
        </div>
    </div>
</div>

<script>
    const ctx = document.getElementById('costChart').getContext('2d');
    let chart;

    function refresh() {
        const levy = parseInt(document.getElementById('levy').value);
        const audit = parseInt(document.getElementById('audit').value) / 100;
        const env = parseInt(document.getElementById('env').value);
        const psych = parseInt(document.getElementById('psych').value);
        const match = parseInt(document.getElementById('match').value);
        
        document.getElementById('levy-val').innerText = levy.toLocaleString();
        document.getElementById('audit-val').innerText = (audit * 100).toFixed(0) + '%';
        document.getElementById('env-val').innerText = env.toLocaleString();
        document.getElementById('psych-val').innerText = psych.toLocaleString();
        document.getElementById('match-val').innerText = match.toLocaleString();

        const salaryFixed = 40000;
        const shadowFixed = 15000; 
        const totalManageCost = env + psych + match;

        const costReal = salaryFixed + totalManageCost; 
        const costPay = levy;
        const costShadow = shadowFixed + (audit * (levy * 3)); 

        const dataPoints = [costReal, costShadow, costPay];
        const minCost = Math.min(...dataPoints);

        const statusTag = document.getElementById('status-tag');
        const insightText = document.getElementById('insight-text');

        if (minCost === costShadow) {
            statusTag.innerText = "🚨 现状：企业寻求【挂靠式合规】";
            statusTag.className = "status-bar danger";
            insightText.innerText = "当心理偏见和环境改造成本过高，且监管形同虚设时，企业在理性上会选择灰色地带。建议：通过社工服务降低企业沟通焦虑。";
        } else if (minCost === costPay) {
            statusTag.innerText = "💼 现状：企业支付【不雇佣金】";
            statusTag.className = "status-bar danger";
            insightText.innerText = "征收额低于真实雇佣的总成本。企业认为交钱是更划算的‘赎买’。建议：加大对岗位改造的财政补贴。";
        } else {
            statusTag.innerText = "✅ 现状：达成【真实融合就业】";
            statusTag.className = "status-bar safe";
            insightText.innerText = "恭喜！通过降低物理/心理障碍并维持适度监管，真实就业成为了企业的最优解。";
        }

        if (chart) chart.destroy();
        chart = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: ['真实就业', '非法挂靠', '全额缴费'],
                datasets: [{
                    data: dataPoints,
                    backgroundColor: ['#2ecc71', '#e74c3c', '#3498db'],
                    borderRadius: 5
                }]
            },
            options: {
                indexAxis: 'y',
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: { x: { beginAtZero: true, title: { display: true, text: '年度综合支出 (元)' } } }
            }
        });
    }

    document.querySelectorAll('input').forEach(i => i.addEventListener('input', refresh));
    refresh();
</script>
</body>
</html>
